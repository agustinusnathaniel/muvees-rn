{
  "name": "muvees-expo",
  "main": "expo-router/entry",
  "version": "1.1.2",
  "scripts": {
    "upgrade:tamagui": "yarn up '*tamagui*'@latest '@tamagui/*'@latest",
    "upgrade:tamagui:canary": "yarn up '*tamagui*'@canary '@tamagui/*'@canary",
    "generate-themes": "tamagui generate-themes ./src/lib/styles/theme-builder.ts ./src/lib/styles/theme.ts",
    "up-latest": "yarn upgrade-interactive",
    "start": "cross-env EXPO_NO_DOTENV=1 expo start",
    "dev": "yarn start --dev-client",
    "prebuild": "cross-env EXPO_NO_DOTENV=1 expo prebuild",
    "prebuild:android": "yarn prebuild --platform android",
    "prebuild:ios": "yarn prebuild --platform ios",
    "android": "cross-env EXPO_NO_DOTENV=1 expo run:android",
    "ios": "cross-env EXPO_NO_DOTENV=1 expo run:ios",
    "doctor": "npx expo-doctor@latest",
    "start:production": "cross-env APP_ENV=production yarn start",
    "prebuild:production": "cross-env APP_ENV=production yarn prebuild",
    "prebuild:production:android": "yarn prebuild:production --platform android",
    "prebuild:production:ios": "yarn prebuild:production --platform ios",
    "android:production": "cross-env APP_ENV=production yarn android",
    "ios:production": "cross-env APP_ENV=production yarn ios",
    "build": "cross-env EXPO_NO_DOTENV=1 eas build",
    "build:ios": "yarn build --platform ios",
    "build:android": "yarn build --platform android --local",
    "build:preview:ios": "cross-env APP_ENV=development yarn build:ios --profile preview --non-interactive",
    "build:preview:android": "cross-env APP_ENV=development yarn build:android --profile preview",
    "build:production:ios": "cross-env APP_ENV=production yarn build:ios --profile production",
    "build:production:android": "cross-env APP_ENV=production yarn build:android --profile production",
    "build:production:android-apk": "cross-env APP_ENV=production yarn build:android --profile production-apk",
    "eas:update": "cross-env EXPO_NO_DOTENV=1 eas update --clear-cache",
    "update:all:preview": "cross-env APP_ENV=preview yarn eas:update --channel preview",
    "update:all:production": "cross-env APP_ENV=production yarn eas:update --channel production",
    "update:android": "yarn eas:update --platform=android",
    "update:android:preview": "cross-env APP_ENV=preview yarn update:android --channel preview",
    "update:android:production": "cross-env APP_ENV=production yarn update:android --channel production",
    "update:ios": "yarn eas:update --platform=ios",
    "update:ios:preview": "cross-env APP_ENV=preview yarn update:ios --channel preview",
    "update:ios:production": "cross-env APP_ENV=production yarn update:ios --channel production",
    "credentials:ios:preview": "cross-env APP_ENV=preview eas credentials --platform=ios",
    "credentials:ios:production": "cross-env APP_ENV=production eas credentials --platform=ios",
    "submit:ios:production": "cross-env APP_ENV=production eas submit --platform ios",
    "submit:android:production": "cross-env APP_ENV=production eas submit --platform android",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "yarn biome lint ./src",
    "biome:apply": "yarn biome check --write ./src",
    "type:check": "tsc",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "prepare": "husky"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@biomejs/biome": "^1.9.4",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "2.0.2",
    "@tamagui/cli": "2.0.0-rc.37",
    "@tamagui/config": "2.0.0-rc.37",
    "@tamagui/lucide-icons-2": "2.0.0-rc.37",
    "@tamagui/themes": "2.0.0-rc.37",
    "axios": "1.12.0",
    "babel-preset-expo": "~55.0.8",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "expo": "~55.0.12",
    "expo-build-properties": "~55.0.12",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.11",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.14",
    "expo-updates": "~55.0.19",
    "expo-web-browser": "~55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.83.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "swr": "^2.4.1",
    "tamagui": "2.0.0-rc.37",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/metro-config": "~55.0.9",
    "@expo/metro-runtime": "~55.0.9",
    "@tamagui/babel-plugin": "2.0.0-rc.37",
    "@tamagui/metro-plugin": "2.0.0-rc.37",
    "@types/react": "~19.2.10",
    "commit-and-tag-version": "^12.7.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "yarn@4.4.0",
  "resolutions": {
    "@tamagui/core": "2.0.0-rc.37",
    "@tamagui/web": "2.0.0-rc.37"
  }
}
